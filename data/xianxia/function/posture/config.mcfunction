scoreboard players set #posture_max xx_post_cfg 100

scoreboard players set #posture_health_mult xx_post_cfg 10
scoreboard players set #health_scale xx_post_cfg 10

scoreboard players set #posture_deflect xx_post_cfg 5
scoreboard players set #posture_block xx_post_cfg 10

scoreboard players set #posture_delay xx_post_cfg 40
scoreboard players set #posture_break_ticks xx_post_cfg 40

# Natural posture decay interval, in ticks per 1 posture recovered.
scoreboard players set #decay_high xx_post_cfg 1
scoreboard players set #decay_mid xx_post_cfg 2
scoreboard players set #decay_low xx_post_cfg 3

# Health is stored as Health * 10. These are 7.5, 5, and 2.5 hearts.
scoreboard players set #hp_7_5_hearts xx_post_cfg 150
scoreboard players set #hp_5_hearts xx_post_cfg 100
scoreboard players set #hp_2_5_hearts xx_post_cfg 50

scoreboard players set #display_step xx_post_cfg 10
scoreboard players set #display_idle_ticks xx_post_cfg 40
